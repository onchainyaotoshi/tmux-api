# API key for authenticating requests to /api/* endpoints.
# All API requests must include this as X-API-Key header.
API_KEY=your-api-key-here

# Server port (default: 9993)
PORT=9993

# Set to "false" to disable Swagger UI at /docs
SWAGGER_ENABLED=true

# (Optional) Accounts service URL for Bearer token auth.
# Validates Bearer tokens via GET /api/proxy/me.
# If not set, only API key auth is available — leave empty if you don't need it.
# See: https://github.com/onchainyaotoshi/accounts
# AUTH_ACCOUNTS_URL=http://localhost:9999
