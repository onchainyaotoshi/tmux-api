# Backend
API_KEY=your-api-key-here
PORT=9993
SWAGGER_ENABLED=true

# URL of the Yaotoshi Accounts service.
# Used by the backend to validate Bearer tokens via GET /me.
AUTH_ACCOUNTS_URL=http://localhost:9999

# Frontend (Vite)
# Vite only exposes env vars prefixed with VITE_ to the browser.
# That's why AUTH_ACCOUNTS_URL and VITE_AUTH_ACCOUNTS_URL both exist —
# the backend and frontend each need their own copy.

# OAuth client ID registered in the Accounts service.
VITE_AUTH_CLIENT_ID=your-client-id

# MUST be the same URL as AUTH_ACCOUNTS_URL above.
# Used by the frontend to redirect users to the login page.
VITE_AUTH_ACCOUNTS_URL=http://localhost:9999

# Where the Accounts service redirects back after login.
# Must match the redirect URI registered in your OAuth client.
VITE_AUTH_REDIRECT_URI=http://localhost:5173/callback

# Where to redirect after logout.
VITE_AUTH_POST_LOGOUT_URI=http://localhost:5173
